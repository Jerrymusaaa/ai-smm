{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "./node_modules/.bin/prisma generate --schema=src/prisma/schema.prisma",
    "db:migrate": "./node_modules/.bin/prisma migrate dev --schema=src/prisma/schema.prisma",
    "db:studio": "./node_modules/.bin/prisma studio --schema=src/prisma/schema.prisma",
    "db:push": "./node_modules/.bin/prisma db push --schema=src/prisma/schema.prisma"
  },
  "dependencies": {
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.22.4",
    "prisma": "5.7.1",
    "@prisma/client": "5.7.1",
    "redis": "^4.6.10",
    "ioredis": "^5.3.2",
    "nodemailer": "^6.9.7",
    "resend": "^2.0.0",
    "stripe": "^14.10.0",
    "axios": "^1.6.2",
    "uuid": "^9.0.0",
    "date-fns": "^3.0.6",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "multer": "^1.4.5-lts.1",
    "winston": "^3.11.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/morgan": "^1.9.9",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/uuid": "^9.0.7",
    "@types/multer": "^1.4.11",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/node": "^20.10.6"
  }
}
